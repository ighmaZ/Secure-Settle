# Chainlink CRE / Confidential Compute (fill when integrating real infra)
CRE_PROJECT=secure-settle-otc
CRE_TARGET=local-simulation
CHAINLINK_RPC_URL=
CHAINLINK_PRIVATE_KEY=

# Convergence hackathon token API
# Docs: https://convergence2026-token-api.cldev.cloud/docs
# Documented POST endpoints use EIP-712 signed payload auth (not API keys).
CONVERGENCE_API_BASE_URL=https://convergence2026-token-api.cldev.cloud
CONVERGENCE_TIMEOUT_MS=5000

# Local simulation/storage
SECURE_SETTLE_DATA_PATH=./.local/secure-settle-store.json
SECURE_SETTLE_PROPOSAL_ENCRYPTION_KEY_HEX=
SECURE_SETTLE_ATTESTATION_SIGNING_KEY_HEX=
