# Secret IDs referenced by secure-settle-otc/config.json
secure-settle-proposal-encryption-key: "0xREPLACE_WITH_64_HEX_BYTES"
secure-settle-attestation-signing-key: "0xREPLACE_WITH_64_HEX_BYTES"
